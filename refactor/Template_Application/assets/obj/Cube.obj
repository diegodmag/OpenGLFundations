vn  0.0  1.0  0.0
vn  0.0 -1.0  0.0
vn  1.0  0.0  0.0
vn -1.0  0.0  0.0

# Caras (f) - Definidas como: vértice/textura/normal
f 1/1/1 2/2/1 4/4/1 3/3/1
f 3/1/3 4/2/3 6/4/3 5/3/3
