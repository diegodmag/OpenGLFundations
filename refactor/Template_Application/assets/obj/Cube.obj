v  0.5 -0.5 -0.5

# Coordenadas de textura (vt) - Opcional
vt 0.0 0.0
vt 1.0 0.0
vt 0.0 1.0
vt 1.0 1.0

# Normales (vn) - Útiles para iluminación
vn  0.0  0.0  1.0
